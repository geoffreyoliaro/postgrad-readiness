# Local development
NUXT_PUBLIC_API_BASE=http://localhost:3001/api

# Railway production — set on the WEB service before deploy/rebuild.
# Use your API public URL (include /api suffix):
# NUXT_PUBLIC_API_BASE=https://YOUR-API-SERVICE.up.railway.app/api
#
# Or reference the API service in the same Railway project:
# NUXT_PUBLIC_API_BASE=https://${{postgrad-api.RAILWAY_PUBLIC_DOMAIN}}/api
# (rename "postgrad-api" to match your API service name in Railway)
